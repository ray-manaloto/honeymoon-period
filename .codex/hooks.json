{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_policy.py\"",
            "timeout": 10,
            "statusMessage": "Checking repository safety policy"
          }
        ]
      }
    ]
  }
}
